      "expectPrimaryAny": ["Sam Winch", "Turning Your Ideas Into Content"],
      "expectPrimaryNone": ["Trade-O", "Renee Boardman"]
    },
    {
      "id": "generic-meeting-1",
      "query": "Weekly team meeting but the same problems keep coming up — how do I run it properly?",
      "expectIntent": "nic_waz_meeting",
      "expectPrimaryAny": ["Nic & Waz", "Meeting Structure"],
      "expectPrimaryNone": ["Leadership Skills", "Momentum Meet"]
    },
    {
      "id": "generic-fy-1",
      "query": "Why do tradies feel hopeful at the start of July even when last year was rough?",
      "expectIntent": "fy_hopeful",
      "expectPrimaryAny": ["Two Drunk Accountants", "Financial Jam with Two Drunk"],
      "expectPrimaryNone": ["Momentum Meet 16 July", "Get Ready for EOFY"]
    },
    {
      "id": "generic-eofy-1",
      "query": "What should I do before end of financial year as a tradie business owner?",
      "expectIntent": "eofy_webinar",
      "expectPrimaryAny": ["Get Ready for EOFY", "EOFY Webinar"],
      "expectPrimaryNone": ["Marketing to Survive Tough Times"]
    },
    {
      "id": "generic-systemology-1",
      "query": "My apprentice ignores the checklist — how do I get systems to stick?",
      "expectIntent": ["systemology", "systems_where_to_start"],
      "expectPrimaryAny": ["Systemology Expert Session", "Systemology"],
      "expectPrimaryNone": ["MindMeister", "Mini Systems Sprint"]
    }
  ]
}
