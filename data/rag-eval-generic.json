      "expectPrimaryAny": ["Finding Daily Focus"],
      "expectPrimaryNone": ["Clea Jones", "Mental Roadblocks"]
    },
    {
      "id": "generic-price-objection-1",
      "query": "Customer said my renovation quote is too expensive — what do I say without discounting?",
      "expectIntent": ["pdf_price_objection", "charge_quotes"],
      "expectPrimaryAny": ["Price Objection", "Objection", "Screen Customers", "charge for quotes"],
      "expectPrimaryNone": ["HazardCo"]
    },
    {
      "id": "generic-debtors-1",
      "query": "Invoices sit overdue for months — is there a simple chasing process for tradies?",
      "expectIntent": "pdf_debtor_management",
      "expectPrimaryAny": ["Debtor Management"],
      "expectPrimaryNone": ["Managing Debtors", "Katie Crismale"]
    },
    {
      "id": "generic-content-1",
      "query": "I've got years of on-site stories but never post content — where do I start without sounding like a guru?",
